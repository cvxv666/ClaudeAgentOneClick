{
  "mcpServers": {
    "brain": {
      "command": "UV_PATH/uv",
      "args": ["run", "--directory", "BRAIN_DIR", "python", "-m", "brain"],
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "type": "stdio"
    }
  }
}
